# =====================
# Django Backend
# =====================
SECRET_KEY=your-very-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — LOCAL DEV (used when DATABASE_URL is not set)
DB_NAME=hydrosense_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL — CLOUD (Render / Supabase / Railway / Neon / etc.)
# When set, this takes priority over the individual DB_* vars above.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# CORS (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Internal service-to-service key (FastAPI → Django)
INTERNAL_API_KEY=change-this-to-a-secure-random-key

# Redis — leave blank to use in-memory channel layer (dev only, single process)
# Set this for production or multi-worker deployments
REDIS_URL=

# Media files
MEDIA_URL=/media/
MEDIA_ROOT=media/

# =====================
# FastAPI Service
# =====================
DJANGO_API_URL=http://localhost:8000
DJANGO_API_KEY=change-this-to-a-secure-random-key
FASTAPI_PORT=8001
